      replacement_content: "import { Lead, Project } from \'./types\';\n\nexport const initialProjects: Project[] = [\n  {\n    id: \'proj_1\',\n    titlu: \'Locuin\310\233\304\203 privat\304\203\',\n    categorie: \'Reziden\310\233ial\',\n    descriere: \'Sistem integrat de supraveghere 4K \310\231i alarm\304\203 perimetral\304\203 pentru o vil\304\203 modern\304\203. Automatizarea complet\304\203 a accesului \310\231i controlul iluminatului de la distan\310\233\304\203.\',\n    detaliiComplete: \'Am proiectat \310\231i instalat un sistem premium compus din 8 camere Dahua de 8MP (4K) cu tehnologie AI WizSense pentru detec\310\233ie precis\304\203 oameni/vehicule, o central\304\203 de alarm\304\203 antifurt wireless Ajax cu senzori de mi\310\231care exteriori \310\231i barier\304\203 perimetral\304\203. De asemenea, s-a integrat controlul automat al por\310\233ilor batante Nice \310\231i managementul luminilor ambientale de exterior prin aplica\310\233ia mobil\304\203 dedicat\304\203.\',\n    imagine: \'https://lh3.googleusercontent.com/aida-public/AB6AXuD7PEtJ3A0CZt8rvPapadglOcicNVMwmrXFGOvhepUJN8Vj4fPTQyjecTRlzzjsYV-GKn_9f8Hb-Oi9J02lWr1vkNZJq8X3hdLKi_lDgpk0yhzfJcSjHWIbkZJ2R3a5TB12XjiN8XvXFDirApN8zanrZD8o-fna_6Oon1qCfwo8D0IRioQs1aow4k6BU4vNJn8mAWRgR7k5JrwPUvlzmPa1E_SS-0Di2BhoANJkgCVdmrWOwc58Olmtnw_5D0lGp3-_8WbcxVdvbzCN\',\n    locatie: \'C\303\242mpulung Moldovenesc, Suceava\',\n    camereInstalate: 8,\n    sistemeFolosite: [\'Camere IP 4K WizSense\', \'Alarma Wireless Ajax\', \'Automatizare Por\310\233i Nice\', \'Smart Home Controls\']\n  },\n  {\n    id: \'proj_2\',\n    titlu: \'Birou / hal\304\203 / depozit\',\n    categorie: \'Industrial\',\n    descriere: \'Protec\310\233ie complet\304\203 pentru fluxuri logistice: control acces biometric, detec\310\233ie incendiu \310\231i monitorizare video inteligent\304\203 pentru depozite de mari dimensiuni.\',\n    detaliiComplete: \'Pentru acest hub logistic de peste 2000 mp, s-a optat pentru o infrastructur\304\203 cu cablare pe fibr\304\203 optic\304\203 pentru magistra\310\233ii, o unitate NVR cu 32 de canale \310\231i camere de exterior rezistente tip Bullet de 5MP Hikvision ColorVu (imagine color 24/7). Sistemul este dublat de senzori de fum adresabili gaza\310\233i cu central\304\203 de alarm\304\203 la incendiu \310\231i control acces cu amprent\304\203/carduri RFID pentru personal.\',\n    imagine: \'https://lh3.googleusercontent.com/aida-public/AB6AXuC5fvhitvLKbm_PKT6_0lxbHmVaJwo01Q1XM5MNQEs9WkBbVIvHsLJFuzMHSXUh9gl3snBuFiug2T7S8GR3CmGvgxncpAr1wpFPJKKHd1DHI2pHBY9AVqlqV42WIkohUQGFry11zUk0MZAc75tWO5j8SJH1vVgdTJFPJM0ujvC5eyA6jwbLwB9fbVVwYNFs8wHvG4iaFKEWf6jLYOBXm6WAn4mmdLET8xnLgHpOos7F7wLcQpt6MszdFqAIQrR4JjlKIVXBhmUGqahL\',\n    locatie: \'Zona Industrial\304\203 C\303\242mpulung Moldovenesc\',\n    camereInstalate: 24,\n    sistemeFolosite: [\'Camere Hikvision ColorVu 5MP\', \'NVR 32 Canale H.265+\', \'Sistem Detec\310\233ie Incendiu\', \'Turniche\310\233i Control Acces Biometric\']\n  },\n  {\n    id: \'proj_3\',\n    titlu: \'Spa\310\233iu comercial\',\n    categorie: \'Retail\',\n    descriere: \'Solu\310\233ii antifurt \310\231i monitorizare trafic clien\310\233i pentru showroom-uri premium. Estetic\304\203 discret\304\203 care nu perturb\304\203 designul interior.\',\n    detaliiComplete: \'Montaj de camere ultra-discrete tip Dome cu unghi de vizualizare panoramic (Fisheye) de 360\302\260 integrate direct \303\256n designul de tavan suspendat. Pe l\303\242ng\304\203 monitorizarea securit\304\203\310\233ii bunurilor \310\231i caselor de marcat, software-ul inclus ofer\304\203 analize de heatmap (zonele cele mai vizitate) \310\231i People Counting (num\304\203rarea fluxului de vizitatori) pentru marketing \310\231i optimizarea personalului.\',\n    imagine: \'https://lh3.googleusercontent.com/aida-public/AB6AXuBpme7bq-X3XpFeun3kSkrnX5GVZtAqln2SFahhdIMedEDC0JxsHn7v9zanpUmEsUGxVVwA1IbpzKFlW0jHxt-Vbx73EaHzXemN3-3l7jZ2sEE5d4e5CcqUfryLKpmefYVJWuxrp1LW7GpGy8XaSSm6-xrCVZLIH5_UEBArEl2ZNKjWwQdlCx3GLUPSJMwe8LfS8fHNi0uQQZwza5Zghv8E4Jmm5ZJTpmKYdEllMzVE8-5a2tq_S5E68XuzV2ni3wwDwd-9ngXJ02HJ\',\n    locatie: \'Suceava (Bulevardul Principal)\',\n    camereInstalate: 6,\n    sistemeFolosite: [\'Camere Dome Fisheye 6MP\', \'Analize Inteligente Heatmap\', \'Sistem Por\310\233i Antifurt\', \'NVR 8 canale cu backup securizat\']\n  },\n  {\n    id: \'proj_4\',\n    titlu: \'Pensiune / unitate turistic\304\203\',\n    categorie: \'Turism\',\n    descriere: \'Check-in automatizat cu yale inteligente \310\231i supraveghere video a zonelor comune pentru siguran\310\233a turi\310\231tilor \310\231i a personalului.\',\n    detaliiComplete: \'O lucrare special\304\203 realizat\304\203 \303\256n stil tradi\310\233ional din lemn, unde provocarea a fost ascunderea complet\304\203 a cablajelor f\304\203r\304\203 a afecta estetica natural\304\203. S-au instalat yale inteligente Yale Linus inteligente integrabile cu Airbnb (coduri de acces generate automat pe durata rezerv\304\203rii) \310\231i camere exterioare rezistente la temperaturi extreme \310\231i viscol, asigur\303\242nd monitorizarea parc\304\203rii \310\231i a c\304\203ilor de acces.\',\n    imagine: \'https://lh3.googleusercontent.com/aida-public/AB6AXuCY6T6WvyW4QXXZYWtvR8H2bwmtoTWlHvT-5M0ZAVenLAi8ee0LnXyYqaAVIYvE18tJcRktesMvTvbZL1nB10pZrt6iIlUdQraRAp9dYtW_fBg3RtJeHZIMSLrhQAVP0WqL9IETBe_QYU7N844D6MrGiX714ZHP5cstqt0eWCwPWR89vmtFGAKIBaKXeXiXh_qsWZOA619mDpucrFe_5Swn_X-o5O0AAverTphqP_l4VcOI158trNWc84Mwi9pE8im_xV_bnsit_Wrj\',\n    locatie: \'Gura Humorului, Bucovina\',\n    camereInstalate: 12,\n    sistemeFolosite: [\'Camere Premium IP de exterior 4MP\', \'Yale Inteligente cu control PIN/Aplica\310\233ie\', \'Re\310\233ea Wi-Fi Mesh Outdoor\', \'Central\304\203 Monitorizare Video\']\n  }\n];\n\nexport const initialLeads: Lead[] = [\n  {\n    id: \'lead_1\',\n    nume: \'Popescu Ion\',\n    telefon: \'0745123456\',\n    email: \'ion.popescu@gmail.com\',\n    localitate: \'C\303\242mpulung Moldovenesc\',\n    tipLocatie: \'rezidential\',\n    tipServiciu: \'nou\',\n    camere: 4,\n    mesaj: \'Sistem Supraveghere Vil\304\203 nou construit\304\203. Doresc monitorizare exterior total\304\203 \310\231i preg\304\203tire cablaj \303\256n faza de finisaje.\',\n    data: \'Azi, 10:24\',\n    status: \'nou\',\n    valoare: 3200\n  },\n  {\n    id: \'lead_2\',\n    nume: \'Mihai Andrei\',\n    telefon: \'0722987654\',\n    email: \'andrei.mihai@outlook.com\',\n    localitate: \'Pojor\303\242ta\',\n    tipLocatie: \'rezidential\',\n    tipServiciu: \'nou\',\n    camere: 2,\n    mesaj: \'Automatizare pentru por\310\233i batante de fier forjat de 3.5m total. Plus camer\304\203 video de exterior spre poart\304\203.\',\n    data: \'Azi, 08:15\',\n    status: \'nou\',\n    valoare: 2450\n  },\n  {\n    id: \'lead_3\',\n    nume: \'Elena Vasilescu\',\n    telefon: \'0753001122\',\n    email: \'elena.v@yahoo.com\',\n    localitate: \'C\303\242mpulung Moldovenesc\',\n    tipLocatie: \'rezidential\',\n    tipServiciu: \'upgrade\',\n    camere: 3,\n    mesaj: \'Sistem Alarm\304\203 Apartament etaj 1. Am deja ni\310\231te senzori dar sunt pe baterie vechi de 8 ani \310\231i vreau ceva modern controlabil de pe telefon.\',\n    data: \'Ieri, 16:45\',\n    status: \'contactat\',\n    valoare: 1800\n  },\n  {\n    id: \'lead_4\',\n    nume: \'Hotel Central\',\n    telefon: \'0740556677\',\n    email: \'contact@hotelcentral-campulung.ro\',\n    localitate: \'C\303\242mpulung Moldovenesc\',\n    tipLocatie: \'comercial\',\n    tipServiciu: \'upgrade\',\n    camere: 16,\n    mesaj: \'Upgrade 16 camere IP. \303\216nlocuirea celor analogice vechi \310\231i instalarea unui server NVR performant pentru re\310\233inerea \303\256nregistr\304\203rilor conform legii (30 zile).\',\n    data: \'25 Mai 2026\',\n    status: \'programare\',\n    valoare: 12500,\n    programareData: \'24 Iun, 14:00\'\n  },\n  {\n    id: \'lead_5\',\n    nume: \'Resedin\310\233a S.V.\',\n    telefon: \'0752112233\',\n    email: \'sergiu.val@gmail.com\',\n    localitate: \'Vama, Suceava\',\n    tipLocatie: \'rezidential\',\n    tipServiciu: \'nou\',\n    camere: 6,\n    mesaj: \'Instalare Smart Home \310\231i camere de exterior. Doresc integrare complet\304\203 cu iluminatul inteligent \310\231i alarm\304\203 antifurt Ajax.\',\n    data: \'22 Mai 2026\',\n    status: \'lucru\',\n    valoare: 8400,\n    progress: 65\n  },\n  {\n    id: \'lead_6\',\n    nume: \'Constantin Marinescu\',\n    telefon: \'0744889900\',\n    email: \'office@cm-security.ro\',\n    localitate: \'C\303\242mpulung Moldovenesc\',\n    tipLocatie: \'industrial\',\n    tipServiciu: \'nou\',\n    camere: 12,\n    mesaj: \'Detec\310\233ie perimetral\304\203 \310\231i camere video de \303\256nalt\304\203 rezolu\310\233ie pentru curte logistic\304\203.\',\n    data: \'15 Mai 2026\',\n    status: \'finalizat\',\n    valoare: 4200\n  },\n  {\n    id: \'lead_7\',\n    nume: \'Asocia\310\233ia de Locatari nr. 4\',\n    telefon: \'0731445566\',\n    email: \'contact@asoc4.ro\',\n    localitate: \'Suceava\',\n    tipLocatie: \'public\',\n    tipServiciu: \'mentenanta\',\n    camere: 5,\n    mesaj: \'Mentenan\310\233\304\203 lunar\304\203 sistem de supraveghere pe 2 sc\304\203ri de bloc \310\231i parcare exterioar\304\203.\',\n    data: \'10 Mai 2026\',\n    status: \'lucru\',\n    valoare: 1500,\n    progress: 100\n  }\n];\n"
